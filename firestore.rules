rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Reusable Security Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Restrict editing authority ONLY to the verified, authenticated owner Anadhi
    function isVerifiedOwner() {
      return isSignedIn() && 
             request.auth.token.email == "asharma9albs@gmail.com" && 
             request.auth.token.email_verified == true;
    }
    
    // Guard against SQL/character injection attacks on Document ID strings
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- COLLECTION RULES FOR PORTFOLIO SECTIONS ---

    // Profiles Configuration Documents
    match /profiles/{profileId} {
      allow read: if true; // Public access to reading profile summaries
      allow write: if isVerifiedOwner() && isValidId(profileId);
    }

    // Work Experience Timeline Items
    match /experiences/{experienceId} {
      allow read: if true;
      allow write: if isVerifiedOwner() && isValidId(experienceId);
    }

    // Academic Credentials
    match /education/{educationId} {
      allow read: if true;
      allow write: if isVerifiedOwner() && isValidId(educationId);
    }

    // Grouped Tool & Skill Categories
    match /skills/{skillId} {
      allow read: if true;
      allow write: if isVerifiedOwner() && isValidId(skillId);
    }

    // Specializations and Certificates
    match /certifications/{certificationId} {
      allow read: if true;
      allow write: if isVerifiedOwner() && isValidId(certificationId);
    }

    // Corporate Cover Letter Text
    match /cover_letter/{letterId} {
      allow read: if true;
      allow write: if isVerifiedOwner() && isValidId(letterId);
    }

    // Thesis abstract and ML specifications
    match /thesis/{thesisId} {
      allow read: if true;
      allow write: if isVerifiedOwner() && isValidId(thesisId);
    }

    // Secure attachments and documents vault
    match /documents/{documentId} {
      allow read: if true;
      allow write: if isVerifiedOwner() && isValidId(documentId);
    }

  }
}
